---
import { markdownify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

type Props = {
  members: CollectionEntry<"about">["data"]["members"];
};

const {
  members: { title, description, image },
} = Astro.props;
---

<section class="section">
  <div class="container">
    <div class="row">
      <div class="mx-auto text-center lg:col-6">
        <h2 set:html={markdownify(title)} />
        <p class="mt-4" set:html={markdownify(description)} />
      </div>
    </div>
    <div class="row mt-12 justify-center">
      <Image
        src={image}
        alt="Our Members"
        class="w-full rounded-xl object-cover"
        width={500}
        height={500}
      />
    </div>
  </div>
</section>
