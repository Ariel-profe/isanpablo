---
import { markdownify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";
const { banner } = Astro.props;
const { title, button, image, content } = banner;
---

<section class="section banner relative min-h-[calc(100vh-80px)] flex items-center">
  <div class="container">
    <div class="flex flex-col lg:flex-row items-center justify-between gap-12">
      <div class="flex-1 space-y-6">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight" set:html={markdownify(title)} />

        <p class="text-lg md:text-xl text-slate-600 leading-relaxed max-w-2xl" set:html={markdownify(content)} />

        {
          button.enable && (
            <div class="pt-4">
              <a class="btn btn-primary shadow-lg hover:shadow-md transition-all" href={button.link}>
                {button.label}
              </a>
            </div>
          )
        }
      </div>
      <div class="flex-1 max-w-2xl">
        <div class="relative">
          <div class="absolute -inset-6 bg-linear-to-br from-primary/10 to-primary/5 rounded-3xl blur-3xl opacity-60"></div>
          <Image
            class="relative w-full h-auto object-cover rounded-2xl shadow-2xl"
            alt="banner"
            src={image}
            width={603}
            height={396}
          />
        </div>
      </div>
    </div>
  </div>

  <!-- Decorative elements -->
  <div class="absolute top-0 right-0 -z-10 w-1/3 h-1/3 bg-linear-to-bl from-primary/5 to-transparent blur-3xl"></div>
  <div class="absolute bottom-0 left-0 -z-10 w-1/3 h-1/3 bg-linear-to-tr from-primary/5 to-transparent blur-3xl"></div>
  
  <Image
    class="banner-shape absolute -top-28 right-0 -z-1 w-full max-w-[30%]"
    alt="banner"
    src="/images/banner-shape.png"
    width={496}
    height={466}
  />
</section>
